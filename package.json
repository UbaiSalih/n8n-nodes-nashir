{
  "name": "n8n-nodes-nashir",
  "version": "0.6.1",
  "description": "n8n community nodes for nashir.ai — publish to Facebook, Instagram, TikTok, LinkedIn, YouTube, WhatsApp and Telegram, plus AI conversation management",
  "keywords": [
    "n8n-community-node-package",
    "nashir",
    "social media",
    "facebook",
    "instagram",
    "tiktok",
    "linkedin",
    "youtube",
    "whatsapp",
    "telegram",
    "ai",
    "chatbot",
    "conversation-history"
  ],
  "license": "MIT",
  "homepage": "https://nashir.ai",
  "author": "nashir.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/UbaiSalih/n8n-nodes-nashir"
  },
  "main": "index.js",
  "files": [
    "dist",
    "nodes",
    "credentials",
    "package.json"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-icons.js",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/NashirApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/NashirFacebook/NashirFacebook.node.js",
      "dist/nodes/NashirInstagram/NashirInstagram.node.js",
      "dist/nodes/NashirTikTok/NashirTikTok.node.js",
      "dist/nodes/NashirLinkedIn/NashirLinkedIn.node.js",
      "dist/nodes/NashirYouTube/NashirYouTube.node.js",
      "dist/nodes/NashirWhatsApp/NashirWhatsApp.node.js",
      "dist/nodes/NashirTelegram/NashirTelegram.node.js",
      "dist/nodes/NashirContact/NashirContact.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "n8n-workflow": "^2.13.1",
    "typescript": "^5.9.3"
  }
}
